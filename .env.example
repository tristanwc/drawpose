# Backend env vars
PINTEREST_CLIENT_ID=your_client_id_here
PINTEREST_CLIENT_SECRET=your_client_secret_here

# Redirect URI (must match what's registered in Pinterest developer portal)
PINTEREST_REDIRECT_URI=http://localhost:3001/api/auth/callback

ALLOWED_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Session encryption key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=your_random_64_char_hex_here

# Server port (Render assigns this dynamically; defaults to 3001 locally)
PORT=3001

# Set to "production" when deploying
NODE_ENV=development

# --- Production overrides (set these in Render dashboard, not here) ---
# PINTEREST_REDIRECT_URI=https://<your-app>.onrender.com/api/auth/callback
# ALLOWED_ORIGIN=https://<your-app>.onrender.com
# FRONTEND_URL=https://<your-app>.onrender.com
