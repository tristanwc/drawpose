# Backend env vars
PINTEREST_CLIENT_ID=your_client_id_here
PINTEREST_CLIENT_SECRET=your_client_secret_here

# Redirect URI (must match what's registered in Pinterest developer portal)
PINTEREST_REDIRECT_URI=http://localhost:3001/api/auth/callback

ALLOWED_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Frontend env vars (set at build time, not in .env for prod)
# VITE_API_URL=https://your-backend.onrender.com
# VITE_BASE_PATH=/croquis-app/
